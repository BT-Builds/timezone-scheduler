{
  "info": {
    "name": "timezone-scheduler API",
    "description": "BT Builds API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://timezone-scheduler-livid.vercel.app",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "free-demo-key",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Convert Timezone",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/convert",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "convert"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"datetime\": \"\",\n  \"from_timezone\": \"\",\n  \"to_timezone\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Validate Business Hours",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/business-hours-validate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "business-hours-validate"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"timezone\": \"\",\n  \"start_time\": \"\",\n  \"end_time\": \"\",\n  \"working_days\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Schedule Meeting",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/schedule-meeting",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "schedule-meeting"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_datetime\": \"\",\n  \"duration_hours\": 0,\n  \"attendee_timezones\": 0,\n  \"business_hours\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Get Timezone Info",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/timezone-info",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "timezone-info"
          ]
        }
      }
    },
    {
      "name": "Get Next Business Time",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/next-business-time",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "next-business-time"
          ]
        }
      }
    }
  ]
}